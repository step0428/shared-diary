rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 用户文档 - 登录后可读，自己的可写
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // 日记 - 登录后可读，创建者和共建者可写
    match /diaries/{diaryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId ||
                     (resource.data.coAuthors != null && request.auth.uid in resource.data.coAuthors);
      allow delete: if request.auth.uid == resource.data.userId ||
                    (resource.data.coAuthors != null && request.auth.uid in resource.data.coAuthors);
    }

    // 链接 - 登录后可读写，链接双方都可以删除
    match /links/{linkId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth.uid == resource.data.userId || resource.data.acceptedBy == request.auth.uid;
    }

    // 评论 - 登录后可读写，评论作者或日记主人可删除
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId || request.auth.uid == resource.data.diaryOwnerId;
    }

    // 纪念日 - 登录后可读写，创建者和共建者可删除
    match /anniversaries/{anniversaryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId ||
                     (resource.data.coAuthors != null && request.auth.uid in resource.data.coAuthors);
      allow delete: if request.auth.uid == resource.data.userId ||
                    (resource.data.coAuthors != null && request.auth.uid in resource.data.coAuthors);
    }
  }
}